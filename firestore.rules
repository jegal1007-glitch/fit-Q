// DRAFT
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for WrongAnswer
    function isValidWrongAnswer(data) {
      return data.keys().hasAll(['userId', 'question', 'failedAt', 'correctCount']) 
          && data.userId == request.auth.uid
          && data.failedAt is number
          && data.correctCount is number;
    }

    match /test/{testId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidWrongAnswer(request.resource.data);
      allow update: if isSignedIn() 
                    && resource.data.userId == request.auth.uid
                    && isValidWrongAnswer(request.resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['failedAt', 'correctCount']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
